# ============================================================
# JobClaw — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it contains secrets!
# ============================================================

# ─── Database ────────────────────────────────────────────────
# PostgreSQL production database. If left blank, local development falls back to SQLite.
# Railway Postgres example: DATABASE_URL=${{Postgres.DATABASE_URL}}
# Neon example format: postgresql://real_user:real_password@real-host/neondb?sslmode=require
DATABASE_URL=
# Bound transient Postgres connection stalls in GitHub/Railway workers.
JOBCLAW_PG_CONNECT_TIMEOUT=15
JOBCLAW_PG_CONNECT_RETRIES=3


# ─── Discord — Per-category webhook URLs ─────────────────────
# Create per channel: Server Settings → Integrations → Webhooks → New Webhook
# At least one must be set. Jobs without a matching webhook fall back to the first set.
DISCORD_WEBHOOK_AI=
DISCORD_WEBHOOK_SWE=
DISCORD_WEBHOOK_DATA=
DISCORD_WEBHOOK_NEWGRAD=
DISCORD_WEBHOOK_PRODUCT=
DISCORD_WEBHOOK_RESEARCH=
DISCORD_WEBHOOK_GENERAL=

# Defaults to dry-run for production hardening. Set to false/0 only after
# validating scrape quality and Discord card previews.
JOBCLAW_DISCORD_DRY_RUN=0
# Reject aggregator/search/salary pages before Discord posting.
JOBCLAW_DISCORD_STRICT_QUALITY=1
# Keep Discord focused on US/Remote-US roles and read newest jobs first.
JOBCLAW_DISCORD_US_ONLY=1
JOBCLAW_DISCORD_LOOKBACK_HOURS=24
JOBCLAW_DISCORD_CANDIDATE_LIMIT=1000
# Keep scheduled Discord pushes bounded; 75 cards takes roughly 1-2 minutes.
JOBCLAW_DISCORD_MAX_POSTS=75

# GitHub catch-up controller SLOs. The controller reads DB history and runs
# overdue jobs when GitHub cron wakes late or skips individual tier workflows.
JOBCLAW_CONTROLLER_HOT_INTERVAL_MINUTES=20
JOBCLAW_CONTROLLER_FAST_INTERVAL_MINUTES=75
JOBCLAW_CONTROLLER_MEDIUM_INTERVAL_MINUTES=90
JOBCLAW_CONTROLLER_DISCORD_INTERVAL_MINUTES=15

# ─── Twitter / X digest ──────────────────────────────────────
# Posts ONE summary tweet of new roles every ~3h (not per-job). Stays dry-run
# until JOBCLAW_TWITTER_DRY_RUN=0 AND all four X_* keys are set (from an X
# developer app with WRITE permission). X has no free tier (pay-per-use); ~8
# plain posts/day at $0.015 ≈ $3.60/mo. Set a spending limit in the X console.
JOBCLAW_TWITTER_DRY_RUN=1
JOBCLAW_TWITTER_WINDOW_HOURS=3
# Keep 0: X charges $0.20 for a post containing a URL vs $0.015 plain (~13x).
# Leave the link out of the tweet and put your job-board URL in the X bio.
JOBCLAW_TWITTER_INCLUDE_URL=0
# Set 1 ONLY if your X account has Premium (allows long posts >280 chars). When 0,
# the digest auto-trims (drops picks, then the tagline) to fit the 280-char limit.
JOBCLAW_TWITTER_LONG=0
JOBCLAW_WEB_URL=https://norinote.xyz
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ─── API Security ────────────────────────────────────────────
# Set a strong random string to enable X-API-Key auth on the FastAPI server.
# REQUIRED IN PRODUCTION: when blank, mutating/admin endpoints (/scraper/trigger,
# /admin/*, /applications writes, /resume) FAIL CLOSED with 503 — public GET reads
# (/jobs, /stats, /companies) still work without a key so the website is unaffected.
JOBCLAW_API_KEY=
# Optional: server-side tenant id for the single-user application tracker.
JOBCLAW_USER_ID=default
# Optional: cap concurrent /ws/jobs WebSocket connections (DoS guard).
JOBCLAW_WS_MAX_CLIENTS=200
# Read-through cache TTL (seconds) for /jobs, /stats, /companies. Collapses repeated
# website polls into one DB query per window — the main lever for DB egress/cost.
# Set to 0 to disable. 300s (5 min) pairs with the web board's 5-min poll.
JOBCLAW_READ_CACHE_TTL=300
# Bound stored job descriptions and trim low-value rows so managed Postgres free
# tiers do not hit Neon-style transfer/storage pressure. The public /jobs list is
# description-free by default; /jobs/{internal_hash} still returns full detail.
JOBCLAW_DESCRIPTION_MAX_CHARS=4000
JOBCLAW_DESCRIPTION_CLEAR_AFTER_DAYS=3
JOBCLAW_RETENTION_REJECTED_DAYS=3
JOBCLAW_RETENTION_NEEDS_REVIEW_DAYS=3
JOBCLAW_RETENTION_ARCHIVED_DAYS=7
JOBCLAW_RETENTION_INACTIVE_DAYS=7
JOBCLAW_RETENTION_INACTIVE_ACCEPTED_DAYS=30
JOBCLAW_RETENTION_FINGERPRINT_DAYS=180
JOBCLAW_RETENTION_SCRAPER_RUNS=500
# Public board snapshot cache. Keeps website traffic off DB-backed /jobs.
JOBCLAW_BOARD_SNAPSHOT_TTL_SECONDS=300
JOBCLAW_BOARD_SNAPSHOT_MAX_JOBS=1000
JOBCLAW_BOARD_FRESHNESS_HOURS=48
JOBCLAW_WORKDAY_SWEEP_MAX_TOTAL_JOBS=50000
JOBCLAW_WORKDAY_SWEEP_MAX_ACCEPTED_UNPOSTED=1000
JOBCLAW_WORKDAY_SWEEP_MAX_RECENT_BAD_RUNS=2

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-domain.com
# Optional regex for additional allowed origins. Opt-in only — leave blank to avoid
# trusting an entire shared host (e.g. *.up.railway.app).
CORS_ORIGIN_REGEX=

# ─── Web / Job Board ─────────────────────────────────────────
# FastAPI base URL used by the Next.js /api proxy, e.g. https://your-api.up.railway.app
JOBCLAW_API_INTERNAL_URL=
# Optional legacy direct browser API URL. Prefer leaving blank so web calls same-origin /api.
NEXT_PUBLIC_API_URL=
# Demo jobs are disabled by default so production never silently shows placeholders.
NEXT_PUBLIC_ENABLE_MOCK_JOBS=0

# ─── LLM / AI (optional) ─────────────────────────────────────
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.5
OPENAI_API_KEY=

# ─── Task Queue (Railway worker + ARQ) ───────────────────────
# Upstash Redis free tier — get from: console.upstash.com → your database → REST URL
# Format: redis://default:<password>@<host>.upstash.io:6379
REDIS_URL=redis://default:xxxx@us1-xxxx.upstash.io:6379

# ─── Scraper ─────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=
OPENCLAW_API_KEY=
PROXY_URL=
# Maximum due ATS targets claimed by a single scraper run.
JOBCLAW_ATS_TARGET_LIMIT=3000
JOBCLAW_FAST_TARGET_LIMIT=900
JOBCLAW_DEEP_TARGET_LIMIT=1200
JOBCLAW_ORCHESTRATOR_TIMEOUT_SECONDS=1500
JOBCLAW_SKIP_AI_PIPELINE=1
# Adaptive queue rollout mode. Active uses leased DB targets and platform budgets.
JOBCLAW_QUEUE_MODE=active
JOBCLAW_QUEUE_LEASE_SECONDS=300
# Claim this multiple of each platform's attempt budget before final budgeting,
# so one high-score ATS cannot crowd out the rest of a multi-platform run.
JOBCLAW_PLATFORM_CLAIM_MULTIPLIER=4
# Coverage fairness: a target overdue by more than this many days is "aged" and
# claimed ahead of fresher work so the long tail (esp. Workday) never starves.
JOBCLAW_AGING_DAYS=14
# Per-tier freshness SLO overrides (hours). Defaults: P0=0.25, P1=1, P2=24, P3=168.
# JOBCLAW_TIER_INTERVAL_P2_HOURS=336
# Override a platform's per-run time budget (seconds); the Workday sweep sets this high.
# JOBCLAW_PLATFORM_BUDGET_SECONDS_WORKDAY=3000
# Rate-limit resilience: bounded 403/anti-bot retries, and circuit-breaker recovery window.
JOBCLAW_ANTIBOT_RETRIES=2
JOBCLAW_CIRCUIT_RECOVERY_SECONDS=3600
# Max JSON response size parsed from an ATS endpoint (bytes) — memory-exhaustion guard.
JOBCLAW_MAX_RESPONSE_BYTES=26214400
# Railway worker fallback. GitHub Actions is still primary, but Railway can wake
# every few minutes and run only when the DB schedule says GitHub is stale.
JOBCLAW_RAILWAY_STALE_FALLBACK=1
JOBCLAW_RAILWAY_DUE_GATE=1
# Leave unset to use the stale fallback defaults. Set to 0 to hard-disable one job.
# JOBCLAW_RAILWAY_ENABLE_HOT=0
# JOBCLAW_RAILWAY_ENABLE_DISCORD=0
# JOBCLAW_RAILWAY_ENABLE_VALIDATION=0
# JOBCLAW_RAILWAY_ENABLE_FAST=0
# JOBCLAW_RAILWAY_ENABLE_MEDIUM=0
# JOBCLAW_RAILWAY_ENABLE_DEEP=0
# Emergency switch: set to 1 to let Railway run fast/medium/deep even without stale fallback.
JOBCLAW_RAILWAY_BULK_FALLBACK=0
# Per-platform runtime budgets. Runs stop by budget instead of attempting every target.
JOBCLAW_PLATFORM_BUDGET_SECONDS_GREENHOUSE=240
JOBCLAW_PLATFORM_BUDGET_SECONDS_LEVER=240
JOBCLAW_PLATFORM_BUDGET_SECONDS_ASHBY=240
JOBCLAW_PLATFORM_BUDGET_SECONDS_WORKDAY=600
JOBCLAW_PLATFORM_BUDGET_SECONDS_RIPPLING=240
JOBCLAW_BRAVE_TIMEOUT_SECONDS=240
# Safer medium-tier defaults for Workday-heavy scraping.
JOBCLAW_MEDIUM_TARGET_LIMIT=800
JOBCLAW_WORKDAY_SHARDS=16
# Keep CI/Railway green for degraded-but-completed runs unless explicitly hardened.
JOBCLAW_DEGRADED_FAILS_WORKFLOW=0
# Public surfaces prefer verified direct ATS/company-career jobs.
JOBCLAW_DIRECT_SOURCE_ONLY=1
JOBCLAW_BRAVE_ENRICHMENT_ONLY=1
