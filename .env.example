# ============================================================
# JobClaw — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it contains secrets!
# ============================================================

# ─── Database ────────────────────────────────────────────────
# If left blank, uses local SQLite at data/jobclaw.db
# Set DATABASE_URL to a Postgres URL for cloud deployment:
# DATABASE_URL=postgresql://user:password@host:5432/jobclaw
DATABASE_URL=

# ─── Discord ─────────────────────────────────────────────────
# Option A (recommended): Webhook URL — no bot process required
# Create: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Option B: Bot Token + Channel ID (fallback if no webhook URL)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Per-category channel routing (optional)
DISCORD_CHANNEL_AI=
DISCORD_CHANNEL_SWE=
DISCORD_CHANNEL_DATA=
DISCORD_CHANNEL_NEWGRAD=
DISCORD_CHANNEL_PRODUCT=
DISCORD_CHANNEL_RESEARCH=

# ─── API Security ────────────────────────────────────────────
# Set a strong random string to enable X-API-Key auth on the FastAPI server.
# Leave blank to disable auth (dev mode only).
JOBCLAW_API_KEY=

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-domain.com

# ─── LLM / AI (optional) ─────────────────────────────────────
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.5
OPENAI_API_KEY=

# ─── Scraper ─────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=
OPENCLAW_API_KEY=
PROXY_URL=

# ─── Supabase (optional cloud DB) ────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=
