# Discord Bot (required for discord_bot.py)
DISCORD_BOT_TOKEN="your_discord_bot_token"
DISCORD_CHANNEL_ID="your_channel_id"

# OpenClaw Browser Automation (required for scrape_openclaw.py)
MINIMAX_API_KEY="your_minimax_api_key"

# Proxy (optional) — routes all HTTP requests through a proxy
# Supports HTTP, HTTPS, and SOCKS5 (requires aiohttp-socks)
# Examples:
#   PROXY_URL=http://user:pass@proxy-host:8080
#   PROXY_URL=socks5://user:pass@proxy-host:1080
PROXY_URL=
