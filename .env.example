# ============================================================
# JobClaw — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it contains secrets!
# ============================================================

# ─── Database ────────────────────────────────────────────────
# Neon PostgreSQL (production). If left blank, falls back to local SQLite.
# Get from: console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# Bound transient Postgres connection stalls in GitHub/Railway workers.
JOBCLAW_PG_CONNECT_TIMEOUT=15
JOBCLAW_PG_CONNECT_RETRIES=3


# ─── Discord — Per-category webhook URLs ─────────────────────
# Create per channel: Server Settings → Integrations → Webhooks → New Webhook
# At least one must be set. Jobs without a matching webhook fall back to the first set.
DISCORD_WEBHOOK_AI=
DISCORD_WEBHOOK_SWE=
DISCORD_WEBHOOK_DATA=
DISCORD_WEBHOOK_NEWGRAD=
DISCORD_WEBHOOK_PRODUCT=
DISCORD_WEBHOOK_RESEARCH=
DISCORD_WEBHOOK_GENERAL=

# Defaults to dry-run for production hardening. Set to false/0 only after
# validating scrape quality and Discord card previews.
JOBCLAW_DISCORD_DRY_RUN=0
# Reject aggregator/search/salary pages before Discord posting.
JOBCLAW_DISCORD_STRICT_QUALITY=1

# ─── API Security ────────────────────────────────────────────
# Set a strong random string to enable X-API-Key auth on the FastAPI server.
# Leave blank to disable auth (dev mode only).
JOBCLAW_API_KEY=

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-domain.com

# ─── LLM / AI (optional) ─────────────────────────────────────
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.5
OPENAI_API_KEY=

# ─── Task Queue (Railway worker + ARQ) ───────────────────────
# Upstash Redis free tier — get from: console.upstash.com → your database → REST URL
# Format: redis://default:<password>@<host>.upstash.io:6379
REDIS_URL=redis://default:xxxx@us1-xxxx.upstash.io:6379

# ─── Scraper ─────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=
OPENCLAW_API_KEY=
PROXY_URL=
# Maximum due ATS targets claimed by a single scraper run.
JOBCLAW_ATS_TARGET_LIMIT=3000
# Adaptive queue rollout mode. Active uses leased DB targets and platform budgets.
JOBCLAW_QUEUE_MODE=active
JOBCLAW_QUEUE_LEASE_SECONDS=300
# Railway worker fallback. Defaults keep Railway from scheduling anything;
# GitHub Actions owns production timing for all scraper/Discord/validation jobs.
JOBCLAW_RAILWAY_ENABLE_HOT=0
JOBCLAW_RAILWAY_ENABLE_DISCORD=0
JOBCLAW_RAILWAY_ENABLE_VALIDATION=0
JOBCLAW_RAILWAY_ENABLE_FAST=0
JOBCLAW_RAILWAY_ENABLE_MEDIUM=0
JOBCLAW_RAILWAY_ENABLE_DEEP=0
# Emergency switch: set to 1 to let Railway run fast/medium/deep if GitHub is down.
JOBCLAW_RAILWAY_BULK_FALLBACK=0
# Per-platform runtime budgets. Runs stop by budget instead of attempting every target.
JOBCLAW_PLATFORM_BUDGET_SECONDS_GREENHOUSE=240
JOBCLAW_PLATFORM_BUDGET_SECONDS_LEVER=240
JOBCLAW_PLATFORM_BUDGET_SECONDS_ASHBY=240
JOBCLAW_PLATFORM_BUDGET_SECONDS_WORKDAY=600
JOBCLAW_PLATFORM_BUDGET_SECONDS_RIPPLING=240
JOBCLAW_BRAVE_TIMEOUT_SECONDS=240
# Safer medium-tier defaults for Workday-heavy scraping.
JOBCLAW_MEDIUM_TARGET_LIMIT=800
JOBCLAW_WORKDAY_SHARDS=16
# Keep CI/Railway green for degraded-but-completed runs unless explicitly hardened.
JOBCLAW_DEGRADED_FAILS_WORKFLOW=0
# Public surfaces prefer verified direct ATS/company-career jobs.
JOBCLAW_DIRECT_SOURCE_ONLY=1
JOBCLAW_BRAVE_ENRICHMENT_ONLY=1
