# ============================================================
# JobClaw — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it contains secrets!
# ============================================================

# ─── Database ────────────────────────────────────────────────
# Neon PostgreSQL (production). If left blank, falls back to local SQLite.
# Get from: console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require


# ─── Discord — Per-category webhook URLs ─────────────────────
# Create per channel: Server Settings → Integrations → Webhooks → New Webhook
# At least one must be set. Jobs without a matching webhook fall back to the first set.
DISCORD_WEBHOOK_AI=
DISCORD_WEBHOOK_SWE=
DISCORD_WEBHOOK_DATA=
DISCORD_WEBHOOK_NEWGRAD=
DISCORD_WEBHOOK_PRODUCT=
DISCORD_WEBHOOK_RESEARCH=

# ─── API Security ────────────────────────────────────────────
# Set a strong random string to enable X-API-Key auth on the FastAPI server.
# Leave blank to disable auth (dev mode only).
JOBCLAW_API_KEY=

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-domain.com

# ─── LLM / AI (optional) ─────────────────────────────────────
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.5
OPENAI_API_KEY=

# ─── Task Queue (Railway worker + ARQ) ───────────────────────
# Upstash Redis free tier — get from: console.upstash.com → your database → REST URL
# Format: redis://default:<password>@<host>.upstash.io:6379
REDIS_URL=redis://default:xxxx@us1-xxxx.upstash.io:6379

# ─── Scraper ─────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=
OPENCLAW_API_KEY=
PROXY_URL=

